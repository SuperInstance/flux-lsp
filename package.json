{
  "name": "flux-lsp",
  "version": "0.2.0",
  "description": "Language Server Protocol implementation for FLUX .flux.md files",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11"
  },
  "contributes": {
    "languages": [
      {
        "id": "flux.md",
        "aliases": ["FLUX Markdown", "flux"],
        "extensions": [".flux.md"],
        "filenames": ["FLUX"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flux.md",
        "scopeName": "source.flux.md",
        "path": "./grammars/flux.tmLanguage.json"
      }
    ]
  }
}
